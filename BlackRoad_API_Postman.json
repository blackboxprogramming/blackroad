      "item": [
        {
          "name": "Record charge",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "http://localhost:8000/charge",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8000",
              "path": [
                "charge"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_id\": \"cust_123\",\n  \"amount\": 5.00,\n  \"description\": \"API usage charge\"\n}"
