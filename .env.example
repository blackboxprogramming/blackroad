# BlackRoad API environment variables
# Copy to .env and fill in your values

# Server
PORT=4000
FRONTEND_URL=https://blackroad.io
CORS_ORIGIN=*

# Stripe (get keys from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Lucidia LLM (llama.cpp server)
# The LLM server runs separately on port 8083 — see systemd/lucidia-llm.service
