{
  "openapi": "3.0.0",
  "info": {
    "title": "BlackRoad Monetization API",
    "description": "Complete SaaS billing, analytics, and monitoring system for production deployment",
    "version": "1.0.0",
    "contact": {
      "name": "BlackRoad Engineering",
      "email": "engineering@blackroad.com"
    },
    "license": {
      "name": "Proprietary",
      "url": "https://blackroad.com/license"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Main API (Billing & Metering)"
    },
    {
      "url": "http://localhost:8001",
      "description": "Admin Dashboard (Analytics)"
    },
    {
      "url": "http://localhost:8003",
      "description": "Customer Analytics"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Bearer token authentication. Use token from authentication service or admin panel."
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "required": [
          "error",
          "message"
        ],
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "details": {
            "type": "object"
          }
        }
      },
      "ChargeRequest": {
        "type": "object",
        "required": [
          "customer_id",
          "amount",
          "description"
        ],
        "properties": {
          "customer_id": {
            "type": "string",
            "description": "Unique customer identifier"
          },
          "amount": {
            "type": "number",
            "format": "float",
            "description": "Amount in USD"
          },
          "description": {
            "type": "string",
            "description": "Charge description"
          },
          "metadata": {
            "type": "object",
            "description": "Additional metadata"
          }
        }
      },
      "UsageResponse": {
        "type": "object",
        "properties": {
          "customer_id": {
            "type": "string"
          },
          "current_month_usage": {
            "type": "number"
          },
          "monthly_limit": {
            "type": "number"
          },
          "free_tier_hours": {
            "type": "number"
          },
          "paid_hours": {
            "type": "number"
          },
          "current_rate": {
            "type": "string"
          },
          "next_charge_date": {
            "type": "string",
            "format": "date"
          },
          "reset_date": {
            "type": "string",
            "format": "date"
          }
        }
      },
      "HealthStatus": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "healthy",
              "degraded",
              "unhealthy"
            ]
          },
          "database": {
            "type": "string",
            "enum": [
              "up",
              "down"
            ]
          },
          "cache": {
            "type": "string",
            "enum": [
              "up",
              "down"
            ]
          },
          "stripe": {
            "type": "string",
            "enum": [
              "connected",
              "disconnected"
            ]
          },
          "latency_ms": {
            "type": "number"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/charge": {
      "post": {
        "tags": [
          "Billing"
        ],
        "summary": "Record a usage charge",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChargeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Charge recorded successfully"
          },
          "401": {
            "description": "Unauthorized"
          },
          "402": {
            "description": "Payment required"
          }
        }
      }
    },
    "/usage": {
      "get": {
        "tags": [
          "Billing"
        ],
        "summary": "Get current usage",
        "responses": {
          "200": {
            "description": "Usage data retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UsageResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/billing": {
      "post": {
        "tags": [
          "Billing"
        ],
        "summary": "Manage subscription",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "customer_id",
                  "tier"
                ],
                "properties": {
                  "customer_id": {
                    "type": "string"
                  },
                  "tier": {
                    "type": "string",
                    "enum": [
                      "free",
                      "light",
                      "power",
                      "enterprise"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Subscription updated"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/status": {
      "get": {
        "tags": [
          "System"
        ],
        "summary": "API health check",
        "security": [],
        "responses": {
          "200": {
            "description": "System status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthStatus"
                }
              }
            }
          }
        }
      }
    },
    "/api/admin/revenue/total": {
      "get": {
        "tags": [
          "Admin - Revenue"
        ],
        "summary": "Get total revenue",
        "responses": {
          "200": {
            "description": "Total revenue data"
          },
          "403": {
            "description": "Forbidden (admin only)"
          }
        }
      }
    },
    "/api/admin/revenue/daily": {
