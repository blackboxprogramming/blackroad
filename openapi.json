      "get": {
        "tags": [
          "Analytics"
        ],
        "summary": "Get cohort retention analysis",
        "parameters": [
          {
            "name": "cohort_month",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Cohort retention data"
          },
          "403": {
