    "/api/admin/health/database": {
      "get": {
        "tags": [
          "Admin - Health"
        ],
        "summary": "Database health check",
        "responses": {
          "200": {
            "description": "Database status"
          },
          "403": {
            "description": "Forbidden"
          }
        }
      }
    },
    "/api/admin/health/stripe": {
      "get": {
        "tags": [
          "Admin - Health"
        ],
        "summary": "Stripe integration health",
